{
  "version": 2,
  "name": "lscm-website",
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "lscm_hero.mp4", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" }
  ],
  "redirects": [
    { "source": "/portal", "destination": "https://lscm-portal.vercel.app", "statusCode": 302 },
    { "source": "/portal/:path*", "destination": "https://lscm-portal.vercel.app/:path*", "statusCode": 302 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    }
  ]
}
